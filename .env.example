# ============================================================
# ECG Admin Frontend — environment variables
# Copy to `.env.local` for dev, or pass as build-args for Docker.
# NOTE: NEXT_PUBLIC_* values are embedded into the client bundle
# at build time and are visible to browsers. Never put secrets here.
# ============================================================

# Base URL of the backend API, including `/api`.
# Local backend:            http://localhost:3001/api
# Docker compose + nginx:   /api            (same-origin via reverse proxy)
# Direct docker network:    http://backend:3001/api
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Minutes of user inactivity before auto-logout. Defaults to 30.
NEXT_PUBLIC_INACTIVITY_TIMEOUT_MINUTES=30
